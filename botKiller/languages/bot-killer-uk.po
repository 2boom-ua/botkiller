msgstr "Блокувати відсутні JS/cookies/referer"

msgid "Block headless browsers"
msgstr "Блокувати headless-браузери"

msgid "Blocks bots missing JavaScript, cookies, or referer headers."
msgstr "Блокує ботів, у яких відсутні JavaScript, cookies або заголовки referer."

msgid "Enable UA rotation detection"
msgstr "Увімкнути виявлення ротації User-Agent"

msgid "Max different UAs"
msgstr "Максимум різних User-Agent"

msgid "different UAs"
msgstr "різних User-Agent"

msgid "Time window"
msgstr "Часове вікно"

msgid "seconds"
msgstr "секунд"

msgid "Blocks IP if it uses more than X different User-Agents within Y seconds. Helps detect bots that rotate UA to avoid detection."
msgstr "Блокує IP, якщо він використовує більше X різних User-Agent протягом Y секунд. Допомагає виявити ботів, які змінюють User-Agent для уникнення виявлення."

msgid "How it works"
msgstr "Як це працює"

msgid "Detects bots that rotate User-Agent strings to avoid detection."
msgstr "Виявляє ботів, які змінюють рядки User-Agent для уникнення виявлення."

msgid "Example:"
msgstr "Приклад:"

msgid "If an IP uses 3 different User-Agents within 5 seconds → blocked."
msgstr "Якщо IP використовує 3 різних User-Agent протягом 5 секунд → заблоковано."

msgid "When a visitor tries to add an out-of-stock product to cart, their IP is immediately blocked."
msgstr "Коли відвідувач намагається додати до кошика товар, якого немає в наявності, його IP негайно блокується."

msgid "Cart Add Rules"
msgstr "Правила додавання до кошика"

msgid "Enable Cart Add Rules"
msgstr "Увімкнути правила додавання до кошика"

msgid "Format: attempts,seconds,type (0=same product, 1=different products, 2=any adds). Use # for comments."
msgstr "Формат: спроби,секунди,тип (0=той самий товар, 1=різні товари, 2=будь-які додавання). Використовуйте # для коментарів."

msgid "Rule examples:"
msgstr "Приклади правил:"

msgid "Blocks IP after 2 adds of the SAME product within 5 seconds"
msgstr "Блокує IP після 2 додавань ОДНОГО товару протягом 5 секунд"

msgid "Blocks IP after 3 adds of the SAME product within 5 minutes"
msgstr "Блокує IP після 3 додавань ОДНОГО товару протягом 5 хвилин"

msgid "Blocks IP after 2 adds of DIFFERENT products within 5 seconds"
msgstr "Блокує IP після 2 додавань РІЗНИХ товарів протягом 5 секунд"

msgid "Blocks IP after 5 ANY adds within 10 seconds"
msgstr "Блокує IP після 5 БУДЬ-ЯКИХ додавань протягом 10 секунд"

msgid "Note:"
msgstr "Примітка:"

msgid "These rules only apply to non-logged-in users. Blocked IPs are automatically unbanned after the configured time."
msgstr "Ці правила застосовуються лише до незареєстрованих користувачів. Заблоковані IP автоматично розблоковуються після налаштованого часу."

msgid "Blocks IPs that add too many items too quickly"
msgstr "Блокує IP при масовому додаванні товарів"

msgid "Save All Rules"
msgstr "Зберегти правила"

msgid "Cart Remove Rules"
msgstr "Правила видалення з кошика"

msgid "Enable Cart Remove Rules"
msgstr "Увімкнути правила видалення з кошика"

msgid "Format: attempts,seconds,type (0=same product, 1=different products, 2=any removes). Use # for comments."
msgstr "Формат: спроби,секунди,тип (0=той самий товар, 1=різні товари, 2=будь-які видалення). Використовуйте # для коментарів."

msgid "Blocks IP after 5 ANY removes within 5 seconds"
msgstr "Блокує IP після 5 БУДЬ-ЯКИХ видалень протягом 5 секунд"

msgid "Blocks IP after 3 removes of the SAME product within 10 seconds"
msgstr "Блокує IP після 3 видалень ОДНОГО товару протягом 10 секунд"

msgid "Blocks IP after 7 removes of DIFFERENT products within 3 seconds"
msgstr "Блокує IP після 7 видалень РІЗНИХ товарів протягом 3 секунд"

msgid "Blocks IPs that remove too many items too quickly"
msgstr "Блокує IP при масовому видаленні товарів"

